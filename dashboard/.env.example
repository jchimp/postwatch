# ── postwatch dashboard configuration ─────────────────────────────────

# Flask secret key for sessions — use a long random string
SECRET_KEY=change-me-to-a-long-random-string

# Admin login credentials
ADMIN_USER=admin
ADMIN_PASS=admin

# Shared API key — must match what each agent has in its .env
AGENT_API_KEY=changeme-use-a-long-random-string

# Comma-separated list of agent base URLs
AGENTS=http://192.168.1.10:5100,http://192.168.1.11:5100

# How often (seconds) to poll agents for stats snapshots
POLL_INTERVAL_SECONDS=120

# SQLite database path (relative to working directory)
DB_PATH=data/postwatch.db

# Dashboard bind address and port
HOST=0.0.0.0
PORT=5000
