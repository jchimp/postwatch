{% extends "base.html" %}
{% block title_suffix %} — Overview{% endblock %}

{% block head_extra %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Overview</h4>
    <div class="d-flex align-items-center gap-2">
        {% if agents|length > 1 %}
        <select id="agentSelect" class="form-select form-select-sm" style="width:auto">
            {% for a in agents %}
            <option value="{{ a }}">{{ a }}</option>
            {% endfor %}
        </select>
        {% else %}
        <input type="hidden" id="agentSelect" value="{{ agents[0] if agents else '' }}">
        {% endif %}
        <button class="btn btn-sm btn-outline-secondary" onclick="fetchOverview()">⟳ Refresh</button>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col">
        <div class="card stat-card" id="cardStatus">
            <span class="status-dot inactive" id="statusDot"></span>
            <span id="statusText">Loading…</span>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card">
            <div class="stat-value text-success-nord" id="cardSent">—</div>
            <div class="stat-label">Sent Today</div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card">
            <div class="stat-value text-warning-nord" id="cardDeferred">—</div>
            <div class="stat-label">Deferred</div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card">
            <div class="stat-value" style="color:var(--nord12)" id="cardBounced">—</div>
            <div class="stat-label">Bounced</div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card">
            <div class="stat-value" id="cardQueue">—</div>
            <div class="stat-label">Queue Depth</div>
        </div>
    </div>
</div>

<!-- Daily Chart -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">Daily Volume (7 days)</div>
            <div class="card-body">
                <canvas id="dailyChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Hourly Chart -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">Hourly Volume (24 h)</div>
            <div class="card-body">
                <canvas id="hourlyChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
const COLORS = {
    sent:     '#a3be8c',
    deferred: '#ebcb8b',
    bounced:  '#d08770',
    rejected: '#bf616a',
};

const chartOpts = (stacked) => ({
    responsive: true,
    maintainAspectRatio: false,
    animation: { duration: 300 },
    scales: {
        x: {
            stacked,
            grid: { color: '#4c566a33' },
            ticks: { color: '#828997' },
        },
        y: {
            stacked,
            beginAtZero: true,
            grid: { color: '#4c566a33' },
            ticks: { color: '#828997' },
        },
    },
    plugins: {
        legend: { labels: { color: '#d8dee9' } },
    },
});

let dailyChart = null;
let hourlyChart = null;

function getAgent() {
    const el = document.getElementById('agentSelect');
    return el ? el.value : '';
}

function enc(url) { return encodeURIComponent(url); }

async function fetchJSON(path) {
    const r = await fetch(path);
    if (!r.ok) throw new Error(`HTTP ${r.status}`);
    return r.json();
}

function buildChart(canvas, labels, datasets, existing) {
    if (existing) existing.destroy();
    return new Chart(canvas.getContext('2d'), {
        type: 'bar',
        data: { labels, datasets },
        options: chartOpts(true),
    });
}

async function fetchOverview() {
    const agent = getAgent();
    if (!agent) return;
    const a = enc(agent);

    // Status
    try {
        const s = await fetchJSON(`/api/status/${a}`);
        document.getElementById('statusDot').className =
            'status-dot ' + (s.active ? 'active' : 'inactive');
        document.getElementById('statusText').textContent =
            s.active ? 'Active' : 'Inactive';
    } catch { document.getElementById('statusText').textContent = 'Unreachable'; }

    // Live stats (from agent log parser)
    try {
        const st = await fetchJSON(`/api/stats/${a}`);
        const t = st.totals || {};
        document.getElementById('cardSent').textContent = t.sent ?? '—';
        document.getElementById('cardDeferred').textContent = t.deferred ?? '—';
        document.getElementById('cardBounced').textContent = t.bounced ?? '—';
    } catch {}

    // Queue
    try {
        const q = await fetchJSON(`/api/queue/${a}`);
        const el = document.getElementById('cardQueue');
        el.textContent = q.queue_count ?? '—';
        el.style.color = (q.queue_count > 0) ? 'var(--nord11)' : 'var(--nord14)';
    } catch {}

    // Daily chart (from SQLite)
    try {
        const d = await fetchJSON(`/api/chart/daily/${a}?days=7`);
        const labels = d.map(r => r.day);
        const ds = ['sent','deferred','bounced','rejected'].map(k => ({
            label: k.charAt(0).toUpperCase() + k.slice(1),
            data: d.map(r => r[k] || 0),
            backgroundColor: COLORS[k],
        }));
        dailyChart = buildChart(
            document.getElementById('dailyChart'), labels, ds, dailyChart
        );
    } catch {}

    // Hourly chart (from SQLite)
    try {
        const h = await fetchJSON(`/api/chart/hourly/${a}?hours=24`);
        const labels = h.map(r => r.hour ? r.hour.split(' ')[1] + ':00' : '');
        const ds = ['sent','deferred','bounced','rejected'].map(k => ({
            label: k.charAt(0).toUpperCase() + k.slice(1),
            data: h.map(r => r[k] || 0),
            backgroundColor: COLORS[k],
        }));
        hourlyChart = buildChart(
            document.getElementById('hourlyChart'), labels, ds, hourlyChart
        );
    } catch {}
}

// ── Init ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    fetchOverview();
    const sel = document.getElementById('agentSelect');
    if (sel && sel.tagName === 'SELECT') sel.addEventListener('change', fetchOverview);
    setInterval(fetchOverview, 120_000);
});
</script>
{% endblock %}
