# ── postwatch dashboard configuration ─────────────────────────────────

# Flask secret key for sessions — use a long random string
SECRET_KEY=change-me-to-a-long-random-string

# Admin login credentials
ADMIN_USER=admin
ADMIN_PASS=admin

# How often (seconds) to poll agents for stats snapshots
POLL_INTERVAL_SECONDS=120

# SQLite database path (relative to working directory)
DB_PATH=data/postwatch.db

# Dashboard bind address and port
HOST=0.0.0.0
PORT=5000

# Note: The agent API key is automatically generated when the database is first created.
# After logging in, go to Settings to view/regenerate it, then copy it to agent .env files.
# All agents and token thresholds are managed from the dashboard Settings page.
