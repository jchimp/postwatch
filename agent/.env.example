# ── postwatch-agent configuration ──────────────────────────────────────

# Shared secret — must match the dashboard's AGENT_API_KEY
API_KEY=changeme-use-a-long-random-string

# Path to the Postfix mail log
LOG_FILE=/var/log/mail.log

# Bind address and port for the agent API
HOST=0.0.0.0
PORT=5100

# Directory containing token files (all files in this directory will be checked)
TOKEN_DIR=/var/spool/postfix/etc/tokens

# Note: Server name, token thresholds, and other settings are managed centrally
# in the dashboard. Add this agent via Dashboard → Settings → Add Agent.
